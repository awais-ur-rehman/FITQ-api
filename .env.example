# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/FITQ

# JWT
JWT_ACCESS_SECRET=<random-64-char-string>
JWT_REFRESH_SECRET=<different-random-64-char-string>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Redis (Upstash)
REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379

# Gemini (Google AI Studio)
GEMINI_API_KEY=<your-api-key-from-aistudio.google.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Resend
RESEND_API_KEY=re_<your-key>
RESEND_FROM_EMAIL=noreply@fitq.app

# App
CORS_ORIGINS=http://localhost:3000
DAILY_SCAN_LIMIT_FREE=3
DAILY_SCAN_LIMIT_PRO=100
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
